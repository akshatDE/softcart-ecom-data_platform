# Copy to .env and adjust before running `docker compose up`.
# These values are consumed by docker-compose.yml and override
# resources/config/config_file.ini inside the containers via
# SOFTCART_<SECTION>__<KEY> environment variables.

# --- MySQL (OLTP) ---
MYSQL_ROOT_PASSWORD=root_change_me
MYSQL_USER=softcart
MYSQL_PASSWORD=softcart_change_me
MYSQL_DATABASE=softcart_oltp

# --- MongoDB (product catalog) ---
MONGO_USER=softcart
MONGO_PASSWORD=softcart_change_me
MONGO_DATABASE=softcart_catalog

# --- PostgreSQL (staging warehouse + Airflow metadata) ---
POSTGRES_USER=softcart
POSTGRES_PASSWORD=softcart_change_me
POSTGRES_DB=softcart_staging

# --- Airflow ---
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=admin_change_me
AIRFLOW__CORE__FERNET_KEY=

# --- Ollama ---
OLLAMA_MODEL=qwen3.5
# Point containers at an Ollama outside the compose network (e.g. the native
# macOS app with models already downloaded) instead of the bundled container:
#OLLAMA_UPSTREAM_HOST=host.docker.internal

# --- Published host ports (change if another service already uses one) ---
#MYSQL_HOST_PORT=3306
#MONGO_HOST_PORT=27017
#POSTGRES_HOST_PORT=5432
#OLLAMA_HOST_PORT=11434
#AIRFLOW_HOST_PORT=8080
#API_HOST_PORT=8000
#DASHBOARD_HOST_PORT=8501
